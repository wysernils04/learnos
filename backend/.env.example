# ── Supabase ──────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...          # service_role key — NEVER expose to frontend
SUPABASE_JWT_SECRET=your-jwt-secret  # Settings > API > JWT Settings > JWT Secret

# ── Database ──────────────────────────────────────────────────────────
# Direct connection (use pooler URL from Supabase > Settings > Database)
DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres

# ── Security ──────────────────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_SECRET=your-fernet-key-here

# ── CORS ──────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,https://learnos.vercel.app
